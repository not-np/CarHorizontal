@{
    ViewBag.Title = "Prijava na sistem";
}

<div class="row" style="margin-top: 50px;">
    <div class="col-md-4 col-md-offset-4">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title" style="font-weight:bold;">CarHorizontal Prijava</h3>
            </div>
            <div class="panel-body">

                @if (ViewBag.Greska != null)
                {
                    <div class="alert alert-danger">@ViewBag.Greska</div>
                }

                @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                {
                    <div class="form-group">
                        <label>Email adresa:</label>
                        <input type="email" name="email" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Lozinka:</label>
                        <input type="password" name="lozinka" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-success btn-block">Prijavi se</button>
                }

                <div style="margin-top: 15px; text-align: center;">
                    Nemaš nalog? <a href="@Url.Action("Register", "Account")">Registruj se ovdje</a>
                </div>
            </div>
        </div>
    </div>
</div>
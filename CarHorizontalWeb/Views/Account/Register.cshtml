@{
    ViewBag.Title = "Registracija korisnika";
}

<div class="row" style="margin-top: 30px;">
    <div class="col-md-6 col-md-offset-3">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title" style="font-weight:bold;">Kreiraj novi nalog</h3>
            </div>
            <div class="panel-body">

                @if (ViewBag.Greska != null)
                {
                    <div class="alert alert-danger">@ViewBag.Greska</div>
                }

                @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                {
                    <div class="form-group">
                        <label>Ime:</label>
                        <input type="text" name="ime" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Prezime:</label>
                        <input type="text" name="prezime" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Email adresa:</label>
                        <input type="email" name="email" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Lozinka:</label>
                        <input type="password" name="lozinka" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Broj telefona:</label>
                        <input type="text" name="telefon" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Grad:</label>
                        <input type="text" name="grad" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Država:</label>
                        <input type="text" name="drzava" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">Registruj se</button>
                }
                
                <div style="margin-top: 15px; text-align: center;">
                    Već imaš nalog? <a href="@Url.Action("Login", "Account")">Prijavi se ovdje</a>
                </div>
            </div>
        </div>
    </div>
</div>